root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,json,yml,yaml}]
indent_size = 2

[*.cs]
indent_size = 4
# Unity C# default — 4-space indent, K&R braces (Unity team style)

[Makefile]
indent_style = tab
